{
  "spawn_system_name": "Adaptive Spawn and Encounter Ecosystem Engine",
  "version": "1.0.0",
  "description": "Defines rules for dynamic spawn rates, elite promotions, activity-driven escalation, and encounter type balancing.",
  "scaling_formulas": {
    "dynamic_spawn_rate": "BaseRateSeconds / (1.0 + (PlayerActivityScore * 0.25) + (RegionalDangerFactor * 0.15))",
    "elite_promotion_probability": "BaseEliteChance * (1.0 + (PlayerActivityScore * 0.50)) * (1.0 + (HazardLevel * 0.30))",
    "threat_multiplier": "1.0 + (BiomeDifficultyFactor * 0.10) + (EncounterSizeModifier * 0.15)"
  },
  "encounter_type_distribution": {
    "solo": {
      "base_frequency": 0.40,
      "min_monsters": 1,
      "max_monsters": 1,
      "elite_chance_modifier": 1.0,
      "description": "Single high-health wanderer."
    },
    "pack": {
      "base_frequency": 0.45,
      "min_monsters": 2,
      "max_monsters": 5,
      "elite_chance_modifier": 1.2,
      "description": "Coordinated skirmish group sharing aggro."
    },
    "horde": {
      "base_frequency": 0.12,
      "min_monsters": 6,
      "max_monsters": 15,
      "elite_chance_modifier": 0.8,
      "description": "Swarm of weaker units flanking a champion."
    },
    "boss_encounter": {
      "base_frequency": 0.03,
      "min_monsters": 1,
      "max_monsters": 3,
      "elite_chance_modifier": 3.0,
      "description": "Legendary entity accompanied by bodyguards."
    }
  },
  "activity_escalation_tiers": [
    {
      "tier": "Quiet",
      "activity_range": [0, 2],
      "spawn_rate_modifier": 1.0,
      "elite_chance_modifier": 1.0,
      "aggro_range_multiplier": 1.0,
      "description": "Low player count. Monsters spawn in default patterns."
    },
    {
      "tier": "Active",
      "activity_range": [3, 8],
      "spawn_rate_modifier": 1.3,
      "elite_chance_modifier": 1.25,
      "aggro_range_multiplier": 1.1,
      "description": "Moderate player traffic. Mob spawns accelerate; patrols form."
    },
    {
      "tier": "Overrun",
      "activity_range": [9, 15],
      "spawn_rate_modifier": 1.8,
      "elite_chance_modifier": 1.75,
      "aggro_range_multiplier": 1.25,
      "description": "High combat concentration. Portals open, and mini-bosses may spawn."
    },
    {
      "tier": "Cataclysmic",
      "activity_range": [16, 999],
      "spawn_rate_modifier": 2.5,
      "elite_chance_modifier": 2.5,
      "aggro_range_multiplier": 1.5,
      "description": "Extreme raid activity. Regional defenses collapse, triggering zone-wide invasion alerts."
    }
  ],
  "global_density_anchors": {
    "Forest": 0.5,
    "Desert": 0.2,
    "Frozen Tundra": 0.4,
    "Swamp": 0.8,
    "Volcanic Region": 0.7,
    "Sacred Lands": 0.3,
    "Corrupted Zones": 1.0
  }
}
